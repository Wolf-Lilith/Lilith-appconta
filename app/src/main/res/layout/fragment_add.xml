<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@android:color/transparent">

    <EditText
        android:id="@+id/edit_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Descrição (Ex: Aluguel)"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:backgroundTint="@color/purple_primary"
        android:inputType="textCapSentences"
        android:padding="12dp" />

    <EditText
        android:id="@+id/edit_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Valor (R$)"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:backgroundTint="@color/purple_primary"
        android:inputType="numberDecimal"
        android:padding="12dp" />

    <EditText
        android:id="@+id/edit_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Data de Vencimento (Clique para abrir)"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:backgroundTint="@color/purple_primary"
        android:focusable="false"
        android:clickable="true"
        android:inputType="none"
        android:padding="12dp" />

    <EditText
        android:id="@+id/edit_parcels"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Quantidade de Parcelas (Ex: 12)"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:backgroundTint="@color/purple_primary"
        android:inputType="number"
        android:text="1"
        android:padding="12dp" />

    <RadioGroup
        android:id="@+id/radio_group_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp">

        <RadioButton
            android:id="@+id/radio_expense"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Despesa"
            android:textColor="@color/text_primary"
            android:buttonTint="@color/purple_primary"
            android:checked="true" />

        <RadioButton
            android:id="@+id/radio_revenue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Receita"
            android:textColor="@color/text_primary"
            android:buttonTint="@color/purple_primary" />
    </RadioGroup>

    <Button
        android:id="@+id/btn_save"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Salvar Lançamento"
        android:backgroundTint="@color/purple_primary"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:layout_marginTop="32dp" />

</LinearLayout>
